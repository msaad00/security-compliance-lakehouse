.venv/
__pycache__/
*.pyc
.pytest_cache/
build/
dist/
*.egg-info/
.DS_Store
# Root-level safety net; per-package node_modules entries below stay too.
node_modules/

# Next.js workbench
app/web/node_modules/
app/web/.next/
app/web/out/
app/web/*.tsbuildinfo

# React build output ships in the wheel but is a build artifact in git;
# keep the package directory + .gitkeep, ignore everything generated.
src/security_lakehouse/web/dist/*
!src/security_lakehouse/web/dist/.gitkeep

# Terraform state + provider cache
deploy/eks-terraform/.terraform/
deploy/eks-terraform/.terraform.lock.hcl
deploy/eks-terraform/terraform.tfstate*
deploy/eks-terraform/*.tfvars
!deploy/eks-terraform/terraform.tfvars.example
deploy/eks-terraform/crash.log
deploy/eks-terraform/crash.*.log
